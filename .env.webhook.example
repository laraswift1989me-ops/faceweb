# GitHub webhook secret — generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# Port the webhook server listens on (nginx proxies to this, keep internal)
WEBHOOK_PORT=9001

# Branch that triggers a deploy
WEBHOOK_BRANCH=refs/heads/main

# Absolute path to the deploy script
WEBHOOK_SCRIPT=/var/www/html/swiftearn-app/deploy-frontend.sh

# Absolute path for the deploy log
WEBHOOK_LOG=/var/www/html/swiftearn-app/logs/deploy-frontend.log
